# .env.example — template for gojira's runtime configuration.
#
# Copy this file to .env and fill in your real values:
#
#     cp .env.example .env
#     # then edit .env with your editor of choice
#
# The .env file is gitignored; .env.example is NOT (the exception is
# whitelisted in .gitignore), so it stays in version control as
# documentation of the available knobs.
#
# Docker Compose reads .env automatically when you run `docker compose`
# commands from this directory. The same file can also be sourced by a
# shell if you prefer to run the native binary:
#
#     set -a; source .env; set +a
#     gojira crawl EXAMPLE-1
#
# Image tag for the docker-compose-built image (used by both the
# image: line and the build arg). Defaults to "dev" when unset.
GOJIRA_VERSION=dev

# ---------------------------------------------------------------------
# Required — gojira refuses to start without these.
# ---------------------------------------------------------------------

# Jira Cloud base URL. Must be the full https:// URL of your Atlassian
# tenant, with no trailing slash.
#   Example: https://acme.atlassian.net
GOJIRA_SITE=https://your-site.atlassian.net

# Atlassian account email used for HTTP Basic auth against the Jira
# Cloud REST API. This is YOUR email, not a service account name.
GOJIRA_USER=you@example.com

# Atlassian API token. Generate one at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
# Treat this like a password. Never commit it. Rotate it if it leaks.
GOJIRA_TOKEN=replace-with-your-api-token

# Output directory the Markdown tree is written to. Inside the
# container this defaults to /output, which docker-compose.yml
# bind-mounts to ./out on the host. Override only if you have a
# specific reason.
GOJIRA_OUTPUT_DIR=/output

# ---------------------------------------------------------------------
# Optional — defaults shown.
# ---------------------------------------------------------------------

# Maximum crawl depth from the starting issue. 0 = unlimited.
GOJIRA_DEPTH_LIMIT=0

# Maximum number of issues to fetch per run. Protects against
# accidentally crawling the entire backlog.
GOJIRA_ISSUE_CAP=500

# Maximum wall-clock seconds per run. 0 = unlimited.
GOJIRA_TIME_CAP_SECONDS=0

# Concurrent Jira API requests. Be conservative — Atlassian rate
# limits aggressively and a high number here can get your token
# throttled or temporarily blocked.
GOJIRA_CONCURRENCY=3

# When true, re-fetch issues that already exist on disk and overwrite
# them. When false (default), existing files are left untouched.
GOJIRA_REFETCH=false

# When true, fetch and render issue comments. Off by default because
# comments inflate output size and the v0.1 renderer treats them as
# secondary content.
GOJIRA_INCLUDE_COMMENTS=false

# Log verbosity. One of: error, warn, info, debug.
GOJIRA_LOG_LEVEL=info

# Log output format. One of: text (human-readable, default), json
# (one JSON object per line, suitable for log aggregators).
GOJIRA_LOG_FORMAT=text
