{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/neumachen/gojira/schemas/config.schema.json",
  "title": "gojira Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "enum": [
        "gojira.config.v1"
      ]
    },
    "jira": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "base_url": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "api_token": {
          "type": "string"
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dir": {
          "type": "string"
        }
      }
    },
    "log": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "info"
        },
        "format": {
          "type": "string",
          "enum": [
            "text",
            "json"
          ],
          "default": "text"
        }
      }
    },
    "crawl": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "depth_limit": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "issue_cap": {
          "type": "integer",
          "minimum": 0,
          "default": 500
        },
        "time_cap_seconds": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1,
          "default": 3
        },
        "refetch": {
          "type": "boolean",
          "default": false
        },
        "include_comments": {
          "type": "boolean",
          "default": false
        },
        "include_children": {
          "type": "boolean",
          "default": true
        },
        "child_search_limit": {
          "type": "integer",
          "minimum": 0,
          "default": 100
        },
        "epic_link_field": {
          "type": "string",
          "default": ""
        },
        "include_dev_status": {
          "type": "boolean",
          "default": true
        },
        "dev_status_applications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dev_status_data_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "pullrequest",
              "branch",
              "commit",
              "repository",
              "build"
            ]
          }
        },
        "render_null_custom_fields": {
          "type": "boolean",
          "default": false
        },
        "emit_graph": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string",
          "default": "127.0.0.1:50051",
          "description": "gRPC server bind address."
        }
      }
    },
    "mcp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["self", "bridge"],
          "description": "MCP server backend; required by `gojira mcp` at startup, but absent or empty is acceptable for non-mcp commands."
        },
        "allow_writes": {
          "type": "boolean",
          "default": false,
          "description": "When true, expose the mutating MCP tools (create/update/comment/transition); when false (default), they are absent from tools/list."
        }
      }
    }
  }
}
